# Application
ENVIRONMENT=production
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
DEBUG=false

# Redis
REDIS_URL=redis://:redis@localhost:6379/0
REDIS_PASSWORD=redis

# MongoDB
MONGODB_URL=mongodb://admin:admin@localhost:27017/appdb?authSource=admin
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_DB=appdb

# Server
HOST=0.0.0.0
PORT=8080

# Auth
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRY_HOURS=24

# Optional: Email
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
